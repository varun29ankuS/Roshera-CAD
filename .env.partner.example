# Roshera CAD — partner instance environment.
# Copy to `.env` next to docker-compose.partner.yml and fill in every value.
# `docker compose -f docker-compose.partner.yml` reads `.env` automatically.

# --- Required ---

# PostgreSQL password. Used both by the postgres container (POSTGRES_PASSWORD)
# and by the backend's DATABASE_URL. Pick a strong random value.
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# JWT signing secret for the backend. MUST be set and stable across restarts —
# an unset/empty value makes the server generate a random per-process secret,
# which invalidates every issued token on every restart (users get logged out).
# Generate one, e.g.:  openssl rand -hex 32
ROSHERA_JWT_SECRET=change-me-openssl-rand-hex-32

# --- Optional ---

# Frontend WebSocket URL baked in at build time. Defaults to the root-relative
# "/ws", which the browser resolves against the page origin (ws:// on http,
# wss:// on https) — correct for almost every single-origin deployment, TLS
# included, with no rebuild. Set an absolute ws(s):// URL only for a
# split-origin setup, e.g. wss://cad.partner.example/ws.
PUBLIC_WS_URL=/ws

# Anthropic API key. If omitted, the AI command routes return
# 503 ai_not_configured (they fail loudly rather than returning mock output).
ANTHROPIC_API_KEY=

# Log filter for the backend (tracing EnvFilter syntax).
RUST_LOG=info

# Comma-separated browser origins allowed by CORS. Leave empty when the SPA
# reaches the backend same-origin through nginx. Set only for cross-origin
# browser callers. `*` opens CORS to any origin (logged as a warning).
ROSHERA_CORS_ALLOWED_ORIGINS=

# Host port bindings.
HTTP_PORT=8080
API_PORT=8081
